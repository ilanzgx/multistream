---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Fetch github stars at build time
let stars = 0;
try {
  const response = await fetch('https://api.github.com/repos/ilanzgx/multistream');
  if (response.ok) {
    const data = await response.json();
    stars = data.stargazers_count;
  } else {
    console.warn(`GitHub API Error: ${response.status} ${response.statusText}`);
  }
} catch (e) {
  console.error("Failed to fetch github stars", e);
}

const otherLang = lang === 'en' ? 'pt-br' : 'en';
const otherLangLabel = lang === 'en' ? 'PT-BR' : 'EN';
---

<header class="w-full border-b border-[rgba(0,0,0,0.06)] dark:border-white/5 bg-white/80 dark:bg-[#0f1115]/80 backdrop-blur-md sticky top-0 z-50">
  <div class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href={`/${lang}/`} id="header-logo" class="flex items-center gap-3 hover:opacity-80 transition-opacity">
      <div class="w-8 h-8 rounded-lg bg-[#111111] text-[#FFFFFF] dark:bg-[#EAEAEA] dark:text-[#111111] flex items-center justify-center font-bold text-xl border border-[rgba(0,0,0,0.06)] dark:border-[#EAEAEA]">
        M
      </div>
      <span class="hidden sm:inline font-semibold text-lg tracking-tight text-[#111111] dark:text-[#EAEAEA]">Multistream</span>
    </a>

    <nav class="flex items-center gap-4 sm:gap-6">
      <a
        href="https://ko-fi.com/ilanfonseca"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm font-semibold text-gray-800 dark:text-gray-200 hover:opacity-70 transition-opacity flex items-center gap-1.5"
      >
        ☕ <span class="hidden sm:inline">{t('nav.donate')}</span>
      </a>

      <a
        href="https://github.com/ilanzgx/multistream"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 text-sm font-semibold text-gray-800 dark:text-gray-200 hover:opacity-70 transition-opacity group"
      >
        <svg viewBox="0 0 24 24" class="w-5 h-5 fill-current" aria-hidden="true">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"></path>
        </svg>
        <span class="hidden sm:inline">{t('nav.github')}</span>
        {stars > 0 && (
          <span class="inline-flex items-center justify-center px-2 py-0.5 ml-1 gap-1 text-xs font-mono tracking-widest bg-white text-[#111111] border border-[rgba(0,0,0,0.15)] dark:bg-white/10 dark:text-white dark:border-white/20 rounded-full transition-colors shadow-sm">
            <img src="/star-icon.svg" alt="Star" class="w-3 h-3 dark:invert" /> {stars}
          </span>
        )}
      </a>

      <div class="flex items-center gap-2 border-l border-[rgba(0,0,0,0.1)] dark:border-white/10 pl-4 sm:pl-6 ml-2 sm:ml-2">
        <a
          href={`/${otherLang}/`}
          class="text-xs font-bold px-3 h-8 flex items-center justify-center rounded-md border border-[rgba(0,0,0,0.15)] dark:border-white/20 text-[#111111] dark:text-[#EAEAEA] hover:bg-[rgba(0,0,0,0.05)] dark:hover:bg-white/10 transition-colors shadow-sm tracking-wider whitespace-nowrap"
          title="Change Language"
        >
          {otherLangLabel}
        </a>
        <button
          id="theme-toggle"
          class="w-8 h-8 flex items-center justify-center rounded-md border border-[rgba(0,0,0,0.15)] dark:border-white/20 text-[#111111] dark:text-[#EAEAEA] hover:bg-[rgba(0,0,0,0.05)] dark:hover:bg-white/10 transition-colors shadow-sm"
          aria-label="Toggle Dark Mode"
          title="Toggle Theme"
        >
          <!-- Sun icon (shows in dark mode) -->
          <svg class="w-4 h-4 hidden dark:block fill-current" viewBox="0 0 24 24">
            <path d="M12 2.25a.75.75 0 01.75.75v2.25a.75.75 0 01-1.5 0V3a.75.75 0 01.75-.75zM7.5 12a4.5 4.5 0 119 0 4.5 4.5 0 01-9 0zM18.894 6.166a.75.75 0 00-1.06-1.06l-1.591 1.59a.75.75 0 101.06 1.061l1.591-1.59zM21.75 12a.75.75 0 01-.75.75h-2.25a.75.75 0 010-1.5H21a.75.75 0 01.75.75zM17.834 18.894a.75.75 0 001.06-1.06l-1.59-1.591a.75.75 0 10-1.061 1.06l1.59 1.591zM12 18.75a.75.75 0 01.75.75V21a.75.75 0 01-1.5 0v-1.5a.75.75 0 01.75-.75zM6.166 17.834a.75.75 0 00-1.06 1.06l1.59 1.591a.75.75 0 101.06-1.061l-1.591-1.59zM4.5 12a.75.75 0 01-.75.75H1.5a.75.75 0 010-1.5h2.25a.75.75 0 01.75.75zM6.166 6.166a.75.75 0 001.06-1.06l-1.59-1.591a.75.75 0 00-1.061 1.06l1.59 1.591z"></path>
          </svg>
          <!-- Moon icon (shows in light mode) -->
          <svg class="w-4 h-4 block dark:hidden fill-current" viewBox="0 0 24 24">
            <path d="M9.528 1.718a.75.75 0 01.162.819A8.97 8.97 0 009 6a9 9 0 009 9 8.97 8.97 0 003.463-.69.75.75 0 01.981.98 10.503 10.503 0 01-9.694 6.46c-5.799 0-10.5-4.701-10.5-10.5 0-4.368 2.667-8.112 6.46-9.694a.75.75 0 01.818.162z"></path>
          </svg>
        </button>
      </div>
    </nav>
  </div>
</header>

<script>
  const handleToggleClick = () => {
    const element = document.documentElement;
    element.classList.toggle("dark");

    const isDark = element.classList.contains("dark");
    localStorage.setItem("theme", isDark ? "dark" : "light");
  }

  document.getElementById("theme-toggle")?.addEventListener("click", handleToggleClick);
</script>
