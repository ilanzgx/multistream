---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Fetch github stars at build time
let stars = 0;
try {
  const response = await fetch('https://api.github.com/repos/ilanzgx/multistream');
  if (response.ok) {
    const data = await response.json();
    stars = data.stargazers_count;
  } else {
    console.warn(`GitHub API Error: ${response.status} ${response.statusText}`);
  }
} catch (e) {
  console.error("Failed to fetch github stars", e);
}

const otherLang = lang === 'en' ? 'pt-br' : 'en';
const otherLangLabel = lang === 'en' ? 'PT-BR' : 'EN';
---

<header class="w-full border-b border-[rgba(0,0,0,0.06)] dark:border-white/5 bg-white/80 dark:bg-[#0f1115]/80 backdrop-blur-md sticky top-0 z-50">
  <div class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href={`/${lang}/`} id="header-logo" class="flex items-center gap-3 hover:opacity-80 transition-opacity">
      <div class="w-8 h-8 rounded-lg bg-[#111111] text-[#FFFFFF] dark:bg-[#EAEAEA] dark:text-[#111111] flex items-center justify-center font-bold text-xl border border-[rgba(0,0,0,0.06)] dark:border-[#EAEAEA]">
        M
      </div>
      <span class="font-semibold text-lg tracking-tight text-[#111111] dark:text-[#EAEAEA]">Multistream</span>
    </a>

    <nav class="flex items-center gap-6">
      <a
        href={`/${otherLang}/`}
        class="text-sm font-medium text-gray-700 hover:text-[#111111] dark:hover:text-[#EAEAEA] transition-colors"
        title="Change Language"
      >
        {otherLangLabel}
      </a>

      <a
        href="https://ko-fi.com/ilanfonseca"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm font-semibold text-gray-800 dark:text-gray-200 hover:opacity-70 transition-opacity flex items-center gap-1.5"
      >
        ☕ <span class="hidden sm:inline">{t('nav.donate')}</span>
      </a>

      <a
        href="https://github.com/ilanzgx/multistream"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 text-sm font-semibold text-gray-800 dark:text-gray-200 hover:opacity-70 transition-opacity group"
      >
        <svg viewBox="0 0 24 24" class="w-5 h-5 fill-current" aria-hidden="true">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"></path>
        </svg>
        <span>{t('nav.github')}</span>
        {stars > 0 && (
          <span class="inline-flex items-center justify-center px-2 py-0.5 ml-1 gap-1 text-xs font-mono tracking-widest bg-white text-[#111111] border border-[rgba(0,0,0,0.15)] dark:bg-white/10 dark:text-white dark:border-white/20 rounded-full transition-colors shadow-sm">
            <img src="/star-icon.svg" alt="Star" class="w-3 h-3 dark:invert" /> {stars}
          </span>
        )}
      </a>
    </nav>
  </div>
</header>
