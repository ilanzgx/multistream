{
  "name": "multistream",
  "private": true,
  "version": "0.18.3",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "tauri:dev": "bunx tauri dev",
    "tauri:build": "bunx tauri build",
    "version": "bun run scripts/sync-version.ts",
    "typecheck": "bunx vue-tsc -b",
    "test": "vitest run --reporter=tree",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "prepare": "husky",
    "lint": "oxlint && eslint .",
    "lint:fix": "prettier --write . && oxlint --fix && eslint . --fix",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@lucide/vue": "^1.25.0",
    "@tailwindcss/vite": "^4.3.3",
    "@tauri-apps/plugin-deep-link": "^2.4.9",
    "@tauri-apps/plugin-dialog": "~2",
    "@tauri-apps/plugin-fs": "~2",
    "@tauri-apps/plugin-http": "~2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-store": "~2",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@vueuse/core": "^14.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "reka-ui": "^2.10.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.3",
    "vue": "^3.5.40",
    "vue-i18n": "11",
    "vue-sonner": "^2.0.9"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/cli": "^2.11.1",
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vitest/coverage-v8": "^4.1.10",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "^1.73.0",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "oxlint": "^1.74.0",
    "prettier": "^3.9.5",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^7.2.4",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.7"
  },
  "lint-staged": {
    "*.{js,ts,vue}": [
      "prettier --write",
      "oxlint --fix",
      "eslint --fix"
    ],
    "*.rs": "cargo fmt --manifest-path src-tauri/Cargo.toml --"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ],
    "rules": {
      "body-max-line-length": [
        0,
        "always"
      ]
    }
  }
}
